# ==========================================
# HOGMINI ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Instructions: Copy this file to '.env' and fill in your actual values.
# DO NOT COMMIT THE ACTUAL '.env' FILE TO VERSION CONTROL!

# --- Global Environment ---
# Options: development, test, production
NODE_ENV=development

# --- Security ---
# Generate a secure random string for signing JSON Web Tokens
JWT_SECRET=your_super_secret_jwt_key_here

# --- Databases (PostgreSQL) ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
API_DATABASE_URL=postgres://user:password@localhost:5432/hogmini_api
EVALUATION_DATABASE_URL=postgres://user:password@localhost:5432/hogmini_eval

# --- Caching (Redis) ---
# Format: redis://HOST:PORT
REDIS_URL=redis://localhost:6379

# --- Messaging (RabbitMQ) ---
# Format: amqp://USER:PASSWORD@HOST:PORT
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- Service Ports ---
API_PORT=3001
EVALUATION_PORT=3002