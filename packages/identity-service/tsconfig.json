{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@hogmini/shared": ["../shared/src/index.ts"],
      "@hogmini/shared/*": ["../shared/src*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}